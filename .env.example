# OpenSearch Configuration
OPENSEARCH_HOST=your-opensearch-host
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASS=your-password
OPENSEARCH_INDEX=invinsense-alerts-*

# ClickHouse Configuration
CLICKHOUSE_HOST=your-clickhouse-host
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=your-password
CLICKHOUSE_DATABASE=default

# Migration Settings
SPECIAL_LOCATIONS=SOC1,India-DC
BATCH_SIZE=1000
SCROLL_SIZE=5000
PARALLEL_WORKERS=1

# Performance Tuning (Optional)
# CHECKPOINT_INTERVAL: How often to save checkpoints (in number of documents)
# USE_BLOOM_FILTER: Memory-efficient duplicate detection (recommended for 10M+ documents)
CHECKPOINT_INTERVAL=10000
USE_BLOOM_FILTER=true
